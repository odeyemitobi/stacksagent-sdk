# ─────────────────────────────────────────────────────────────────────────────
# Dashboard environment template
#
# DO NOT edit this file for local secrets — it is committed to git as docs.
#
# Setup (one time):
#   cp .env.example .env.local
#
# Next.js automatically loads `.env.local` in development and production builds.
# `.env.local` is gitignored and holds YOUR machine's values.
# ─────────────────────────────────────────────────────────────────────────────

# NestJS API base URL (must be running for Agents, Treasury, Marketplace pages)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stacks network shown in UI (must match wallet + API)
NEXT_PUBLIC_STACKS_NETWORK=testnet

# Deployed treasury vault contract on testnet
NEXT_PUBLIC_TREASURY_CONTRACT_ADDRESS=ST37H9QBWEG9NEC1Y9MW82YFH8Y4GB3SPTPSN38GG.treasury-vault-v2
