# ─────────────────────────────────────────────────────────────────────────────
# API environment template
#
# Setup (one time):
#   cp .env.example .env
#
# NestJS + Prisma load `.env` from this folder. It is gitignored.
# `.env.example` stays in git as documentation only.
# ─────────────────────────────────────────────────────────────────────────────

# Database connection (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stackagent

# Redis for idempotency keys (optional in local dev — bypasses if unavailable)
REDIS_URL=redis://localhost:6379

# Stacks network: testnet | mainnet | devnet
STACKS_NETWORK=testnet
HIRO_API_BASE_URL=https://api.testnet.hiro.so
TREASURY_CONTRACT_ADDRESS=ST37H9QBWEG9NEC1Y9MW82YFH8Y4GB3SPTPSN38GG.treasury-vault-v2

# API server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Required for agent LLM task parsing (runtime package)
OPENAI_API_KEY=sk-your-key-here
