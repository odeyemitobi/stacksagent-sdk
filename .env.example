# StackAgent SDK — Environment Variables
#
# Copy to apps/api/.env and apps/dashboard/.env.local before running locally.
# See apps/api/.env.example and apps/dashboard/.env.example for full lists.

DATABASE_URL=postgresql://postgres:password@localhost:5432/stackagent
REDIS_URL=redis://localhost:6379
STACKS_NETWORK=testnet
OPENAI_API_KEY=sk-your-key-here
